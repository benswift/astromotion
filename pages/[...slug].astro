---
import DeckLayout from "../components/DeckLayout.astro";
import DeckLoader from "../components/DeckLoader.svelte";
import { parseDeckFrontmatter } from "../src/meta.ts";
import fs from "node:fs";
import path from "node:path";

export function getStaticPaths() {
  const decksDir = path.resolve("src/decks");
  const results: Array<{ params: { slug: string }; props: { title: string; description?: string; image?: string; deckPath: string } }> = [];

  for (const entry of fs.readdirSync(decksDir, { withFileTypes: true })) {
    if (entry.isDirectory()) {
      const dirPath = path.join(decksDir, entry.name);

      for (const file of fs.readdirSync(dirPath)) {
        const match = file.match(/^(.+)\.deck\.svx$/);
        if (!match) continue;

        const name = match[1];
        const raw = fs.readFileSync(path.join(dirPath, file), "utf-8");
        const { data } = parseDeckFrontmatter(raw, entry.name);
        const slug = name === "slides" ? entry.name : `${entry.name}/${name}`;
        const deckPath = `/src/decks/${entry.name}/${file}`;

        results.push({
          params: { slug },
          props: { title: data.title ?? entry.name, description: data.description, image: data.image, deckPath },
        });
      }
    } else if (entry.isFile()) {
      const match = entry.name.match(/^(.+)\.deck\.svx$/);
      if (!match) continue;

      const name = match[1];
      const raw = fs.readFileSync(path.join(decksDir, entry.name), "utf-8");
      const { data } = parseDeckFrontmatter(raw, name);
      const deckPath = `/src/decks/${entry.name}`;

      results.push({
        params: { slug: name },
        props: { title: data.title ?? name, description: data.description, image: data.image, deckPath },
      });
    }
  }

  return results;
}

const { title, description, image, deckPath } = Astro.props;
---

<DeckLayout title={title} description={description} image={image}>
  <DeckLoader deckPath={deckPath} client:only="svelte" />
</DeckLayout>

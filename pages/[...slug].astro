---
import DeckLayout from "../components/DeckLayout.astro";
import DeckLoader from "../components/DeckLoader.svelte";
import { parseDeckFrontmatter } from "../src/meta.ts";
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  const decksDir = path.resolve("src/decks");
  const DECK_MD_RE = /^(.+)\.deck\.(md|svx)$/;
  const DECK_SVELTE_RE = /^(.+)\.deck\.svelte$/;
  const results: Array<{ params: { slug: string }; props: Record<string, unknown> }> = [];

  for (const entry of fs.readdirSync(decksDir, { withFileTypes: true })) {
    if (entry.isDirectory()) {
      const dirPath = path.join(decksDir, entry.name);

      for (const file of fs.readdirSync(dirPath)) {
        const mdMatch = file.match(DECK_MD_RE);
        const svelteMatch = file.match(DECK_SVELTE_RE);
        const match = mdMatch || svelteMatch;
        if (!match) continue;

        const name = match[1];
        const isSvelte = !!svelteMatch;
        const filePath = path.join(dirPath, file);
        const slug = name === "slides" ? entry.name : `${entry.name}/${name}`;
        const deckPath = `/src/decks/${entry.name}/${file}`;

        let slidesHtml = "";
        let frontmatter: Record<string, unknown> = {};
        if (!isSvelte) {
          const mod = await import(filePath);
          slidesHtml = mod.default;
          frontmatter = mod.frontmatter ?? {};
        } else {
          const raw = fs.readFileSync(filePath, "utf-8");
          frontmatter = parseDeckFrontmatter(raw, entry.name).data;
        }

        results.push({
          params: { slug },
          props: {
            title: (frontmatter.title as string) ?? entry.name,
            description: frontmatter.description,
            image: frontmatter.image,
            deckPath,
            isSvelte,
            slidesHtml,
          },
        });
      }
    } else if (entry.isFile()) {
      const mdMatch = entry.name.match(DECK_MD_RE);
      const svelteMatch = entry.name.match(DECK_SVELTE_RE);
      const match = mdMatch || svelteMatch;
      if (!match) continue;

      const name = match[1];
      const isSvelte = !!svelteMatch;
      const filePath = path.join(decksDir, entry.name);
      const deckPath = `/src/decks/${entry.name}`;

      let slidesHtml = "";
      let frontmatter: Record<string, unknown> = {};
      if (!isSvelte) {
        const mod = await import(filePath);
        slidesHtml = mod.default;
        frontmatter = mod.frontmatter ?? {};
      } else {
        const raw = fs.readFileSync(filePath, "utf-8");
        frontmatter = parseDeckFrontmatter(raw, name).data;
      }

      results.push({
        params: { slug: name },
        props: {
          title: (frontmatter.title as string) ?? name,
          description: frontmatter.description,
          image: frontmatter.image,
          deckPath,
          isSvelte,
          slidesHtml,
        },
      });
    }
  }

  return results;
}

const { title, description, image, deckPath, isSvelte, slidesHtml } = Astro.props;
---

<DeckLayout title={title} description={description} image={image}>
  {isSvelte ? (
    <DeckLoader deckPath={deckPath} client:only="svelte" />
  ) : (
    <div class="reveal" role="main">
      <div class="slides" set:html={slidesHtml} />
    </div>
  )}
</DeckLayout>

{!isSvelte && (
  <script>
    import Reveal from "reveal.js";

    const deck = new Reveal({
      width: 1280,
      height: 720,
      margin: 0,
      hash: true,
      hashOneBasedIndex: true,
      controls: false,
      navigationMode: "linear",
      transition: "none",
      disableLayout: true,
      display: "grid",
      center: true,
      viewDistance: 10,
    });
    deck.initialize();
  </script>
)}

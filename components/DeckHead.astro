---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Slide deck", image = "/og-image.svg" } = Astro.props;
const base = Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, base);
const imageUrl = new URL(image, base);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<title>{title}</title>

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl.href} />
<meta property="og:type" content="website" />
<meta property="og:image" content={imageUrl.href} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl.href} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

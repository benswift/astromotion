{
  "name": "astromotion",
  "version": "0.1.0",
  "type": "module",
  "description": "Astro integration for markdown-authored slide decks powered by Reveal.js, with a bit of Marp syntax",
  "author": "Ben Swift",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "stylelint": "stylelint 'theme/**/*.css'"
  },
  "exports": {
    ".": "./index.ts",
    "./components/*": "./components/*",
    "./pages/*": "./pages/*",
    "./theme/*": "./theme/*",
    "./src/*": "./src/*"
  },
  "dependencies": {
    "@qrgrid/core": "^0.2.4",
    "@shikijs/rehype": "^3.4.2",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "reveal.js": "^5.2.1",
    "smartypants": "^0.2.2",
    "unified": "^11.0.5",
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "@astrojs/svelte": "^8.0.0",
    "astro": "^6.0.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@astrojs/svelte": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.3.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "linkedom": "^0.18.12",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.5"
    }
  }
}

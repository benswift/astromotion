{
  "name": "astromotion",
  "version": "0.3.0",
  "description": "Astro integration for markdown-authored slide decks powered by Reveal.js, with a bit of Marp syntax",
  "license": "MIT",
  "author": "Ben Swift",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./components/*": "./components/*",
    "./pages/*": "./pages/*",
    "./theme/*": "./theme/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "stylelint": "stylelint 'theme/**/*.css'"
  },
  "dependencies": {
    "@qrgrid/core": "^0.2.4",
    "@shikijs/rehype": "^4.0.2",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "reveal.js": "^6.0.1",
    "unified": "^11.0.5",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@e18e/eslint-plugin": "^0.4.1",
    "astro": "^6.3.1",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "linkedom": "^0.18.12",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@astrojs/mdx": "^5.0.0",
    "astro": "^6.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.5"
    }
  }
}
